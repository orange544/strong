# Baseline minimal env template for contract tests.
# Tests override OUTPUT_DIR, REGISTRY_PATH, and DB_PATHS_JSON at runtime.

PROJECT_ROOT=.
OUTPUT_DIR=outputs
REGISTRY_PATH=ipfs_registry.json

IPFS_API_URL=http://127.0.0.1:5001/api/v0
IPFS_HTTP_TIMEOUT_SEC=10

DB_SAMPLE_RATIO=0.5
DB_SAMPLE_MIN=1
DB_SAMPLE_MAX=5

LLM_API_KEY=test-key
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_MODEL_NAME=qwen3.5-4b
LLM_DESC_API_KEY=test-key
LLM_DESC_BASE_URL=http://127.0.0.1:1234/v1
LLM_DESC_MODEL_NAME=qwen3.5-4b
LLM_UNIFY_API_KEY=test-key
LLM_UNIFY_BASE_URL=http://127.0.0.1:1234/v1
LLM_UNIFY_MODEL_NAME=qwen3.5-4b

LLM_MAX_RETRIES=1
LLM_REQUEST_TIMEOUT_SEC=15
LLM_UNIFY_TIMEOUT_SEC=30
LLM_DESCRIPTION_MAX_TOKENS=96
LLM_UNIFY_MAX_TOKENS=512
LLM_DESC_MAX_WORKERS=1
LLM_DESC_DOMAIN_TIMEOUT=120
RUN_MAX_FIELDS_PER_DOMAIN=0

IPFS_CHAIN_BIN=D:/Program Files/BISHE/program/blockchain/go-norn-main/bin/ipfs-chain.exe
GO_NORN_ROOT=D:/Program Files/BISHE/program/blockchain/go-norn-main
CHAIN_RECEIVER_ADDRESS=0000000000000000000000000000000000000000
CHAIN_RPC_ADDR=127.0.0.1:45558
CHAIN_IPFS_API=http://127.0.0.1:5001
CHAIN_TX_TIMEOUT_SEC=12

AUTO_DB_FOLDER=data/dbs/
AUTO_PREVIOUS_UNIFIED_FIELDS_CID=
AUTO_POLL_INTERVAL_SEC=10
